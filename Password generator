#include<stdio.h>
#include<stdlib.h>
#include<time.h>
void main()
{
  int j,i;
  char pwd[]="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz!@#$&^*";
  printf("Enter the length of password:");
  scanf("%d",&j);
  srand(time(0));
  printf("Genetared password:");
  for(i=0;i<j;i++)
  {
    int index=rand() % (sizeof(pwd)-1);
    printf("%c",pwd[index]);
  }
  
}
